# Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Database
DATABASE_URL=postgresql://ecommerce_user:STRONG_PASSWORD_HERE@postgres:5432/ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE
POSTGRES_DB=ecommerce_db

# Redis
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379/0
REDIS_PASSWORD=REDIS_PASSWORD_HERE

# JWT Authentication
JWT_SECRET=VERY_LONG_RANDOM_SECRET_HERE_AT_LEAST_64_CHARS_USE_openssl_rand_base64_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Backend
ENVIRONMENT=production
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
API_V1_PREFIX=/api/v1

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Frontend
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NODE_ENV=production

# Generate strong passwords:
# openssl rand -base64 32
# openssl rand -base64 64
